@page "/"
@rendermode InteractiveServer
@using VisionSharp
@using VisionSharp.Abstractions.Enums
@using VisionSharp.Processing.Extensions
@using VisionSharp.Extensions
@inject IWebHostEnvironment Env
@implements IDisposable

<PageTitle>VisionSharp – Live Image Editor</PageTitle>

<div class="editor-layout">

    <header class="editor-header">
        <div class="header-brand">
            <span class="brand-vs">VisionSharp</span>
            <span class="brand-sub">Live Image Editor</span>
        </div>
        <p class="header-desc">Adjust the effects below and watch the image update in real-time.</p>
    </header>

    <div class="image-panels">
        <div class="panel">
            <div class="panel-label">Original</div>
            <img src="image-sample.jpg" alt="Original" class="preview-img" />
            <div class="panel-footer">
                <label class="btn-ghost file-label">
                    Replace image
                    <InputFile OnChange="HandleFileUploadAsync" accept="image/*" class="file-input-hidden" />
                </label>
                <div class="url-row">
                    <input class="text-input url-input" type="url" placeholder="https://…"
                           @bind="_urlInput" @bind:event="oninput" />
                    <button class="btn-ghost" @onclick="LoadFromUrlAsync" disabled="@_urlLoading">
                        @(_urlLoading ? "Loading…" : "Load URL")
                    </button>
                </div>
                @if (_urlError is not null)
                {
                    <p class="url-error">@_urlError</p>
                }
            </div>
        </div>

        <div class="panel">
            <div class="panel-label">
                Processed
                @if (_processing)
                {
                    <span class="badge badge-processing">processing…</span>
                }
                else if (_elapsedMs > 0)
                {
                    <span class="badge badge-ok">@_elapsedMs ms</span>
                }
            </div>

            @if (_processedDataUrl is not null)
            {
                <img src="@_processedDataUrl" alt="Processed" class="preview-img" />
            }
            else
            {
                <div class="panel-placeholder"><span class="spinner"></span></div>
            }

            <div class="panel-footer">
                @if (_processedDataUrl is not null)
                {
                    <a class="btn-ghost" href="@_processedDataUrl" download="@($"visionsharp_result.{_outputFormat}")">Download</a>
                }
            </div>
        </div>
    </div>

    <div class="controls-grid">

        <section class="ctrl-card ctrl-wide">
            <h3 class="ctrl-title">Presets</h3>
            <div class="toggle-row">
                <button class="@Cls(_vintage)"     @onclick="async () => { _vintage     = !_vintage;     await ProcessAsync(); }">Vintage</button>
                <button class="@Cls(_blackWhite)"  @onclick="async () => { _blackWhite  = !_blackWhite;  await ProcessAsync(); }">B &amp; W</button>
                <button class="@Cls(_warmTone)"    @onclick="async () => { _warmTone    = !_warmTone;    await ProcessAsync(); }">Warm Tone</button>
                <button class="@Cls(_coolTone)"    @onclick="async () => { _coolTone    = !_coolTone;    await ProcessAsync(); }">Cool Tone</button>
                <button class="@Cls(_softFocus)"   @onclick="async () => { _softFocus   = !_softFocus;   await ProcessAsync(); }">Soft Focus</button>
                <button class="@Cls(_darkOverlay)" @onclick="async () => { _darkOverlay = !_darkOverlay; await ProcessAsync(); }">Dark Overlay</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Color</h3>
            <div class="toggle-row">
                <button class="@Cls(_grayscale)" @onclick="async () => { _grayscale = !_grayscale; await ProcessAsync(); }">Grayscale</button>
                <button class="@Cls(_sepia)"     @onclick="async () => { _sepia     = !_sepia;     await ProcessAsync(); }">Sepia</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Adjust</h3>
            <div class="slider-row">
                <span class="slider-label">Brightness</span>
                <input type="range" min="-100" max="100" value="@_brightness"
                       @oninput="e => OnSlider(e, v => _brightness = v)"
                       class="slider" />
                <span class="slider-val">@(_brightness > 0 ? $"+{_brightness}" : _brightness.ToString())</span>
            </div>
            <div class="slider-row" style="margin-top:.4rem">
                <span class="slider-label">Contrast</span>
                <input type="range" min="-100" max="100" value="@_contrast"
                       @oninput="e => OnSlider(e, v => _contrast = v)"
                       class="slider" />
                <span class="slider-val">@(_contrast > 0 ? $"+{_contrast}" : _contrast.ToString())</span>
            </div>
            <div class="slider-row" style="margin-top:.4rem">
                <span class="slider-label">Opacity</span>
                <input type="range" min="0" max="100" value="@_opacity"
                       @oninput="e => OnSlider(e, v => _opacity = v)"
                       class="slider" />
                <span class="slider-val">@_opacity%</span>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Focus</h3>
            <div class="slider-row">
                <span class="slider-label">Box Blur</span>
                <input type="range" min="0" max="20" value="@_blur"
                       @oninput="e => OnSlider(e, v => _blur = v)"
                       class="slider" />
                <span class="slider-val">@(_blur == 0 ? "off" : _blur.ToString())</span>
            </div>
            <div class="slider-row" style="margin-top:.4rem">
                <span class="slider-label">Gaussian</span>
                <input type="range" min="0" max="50" value="@_gaussianBlur"
                       @oninput="e => OnSlider(e, v => _gaussianBlur = v)"
                       class="slider" />
                <span class="slider-val">@(_gaussianBlur == 0 ? "off" : $"{_gaussianBlur / 10f:F1}σ")</span>
            </div>
            <div class="toggle-row" style="margin-top:.5rem">
                <button class="@Cls(_sharpen)" @onclick="async () => { _sharpen = !_sharpen; await ProcessAsync(); }">Sharpen</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Transform</h3>
            <div class="slider-row">
                <span class="slider-label">Rotate</span>
                <input type="range" min="-180" max="180" value="@_rotate"
                       @oninput="e => OnSlider(e, v => _rotate = v)"
                       class="slider" />
                <span class="slider-val">@_rotate°</span>
            </div>
            <div class="slider-row" style="margin-top:.4rem">
                <span class="slider-label">Scale</span>
                <input type="range" min="25" max="200" value="@_scale"
                       @oninput="e => OnSlider(e, v => _scale = v)"
                       class="slider" />
                <span class="slider-val">@_scale%</span>
            </div>
            <div class="toggle-row" style="margin-top:.5rem">
                <button class="@Cls(_flipH)" @onclick="async () => { _flipH = !_flipH; await ProcessAsync(); }">Flip H</button>
                <button class="@Cls(_flipV)" @onclick="async () => { _flipV = !_flipV; await ProcessAsync(); }">Flip V</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Artistic</h3>
            <div class="slider-row">
                <span class="slider-label">Pixelate</span>
                <input type="range" min="0" max="50" value="@_pixelate"
                       @oninput="e => OnSlider(e, v => _pixelate = v)"
                       class="slider" />
                <span class="slider-val">@(_pixelate == 0 ? "off" : _pixelate.ToString())</span>
            </div>
        </section>

        <section class="ctrl-card ctrl-wide">
            <h3 class="ctrl-title">Text Watermark</h3>
            <input class="text-input" type="text" placeholder="Watermark text…"
                   value="@_watermarkText"
                   @oninput="e => OnWatermarkInput(e)" />
            <select class="ctrl-select" @bind="_watermarkPositionStr" @bind:after="ProcessAsync">
                @foreach (var pos in Enum.GetValues<WatermarkPosition>())
                {
                    <option value="@pos">@FormatPosition(pos)</option>
                }
            </select>
            <div class="slider-row" style="margin-top:.5rem">
                <span class="slider-label">Opacity</span>
                <input type="range" min="0" max="100" value="@_watermarkOpacity"
                       @oninput="e => OnSlider(e, v => _watermarkOpacity = v)"
                       class="slider" />
                <span class="slider-val">@_watermarkOpacity%</span>
            </div>
            <div class="slider-row" style="margin-top:.4rem">
                <span class="slider-label">Font size</span>
                <input type="range" min="12" max="120" value="@_watermarkFontSize"
                       @oninput="e => OnSlider(e, v => _watermarkFontSize = v)"
                       class="slider" />
                <span class="slider-val">@_watermarkFontSize</span>
            </div>
            <div class="toggle-row" style="margin-top:.5rem">
                <button class="@Cls(_showWatermark)" @onclick="async () => { _showWatermark = !_showWatermark; await ProcessAsync(); }">Enable</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Image Watermark</h3>
            <select class="ctrl-select" @bind="_imageWatermarkPositionStr" @bind:after="ProcessAsync">
                @foreach (var pos in Enum.GetValues<WatermarkPosition>())
                {
                    <option value="@pos">@FormatPosition(pos)</option>
                }
            </select>
            <div class="slider-row" style="margin-top:.5rem">
                <span class="slider-label">Opacity</span>
                <input type="range" min="0" max="100" value="@_imageWatermarkOpacity"
                       @oninput="e => OnSlider(e, v => _imageWatermarkOpacity = v)"
                       class="slider" />
                <span class="slider-val">@_imageWatermarkOpacity%</span>
            </div>
            <div class="toggle-row" style="margin-top:.5rem">
                <button class="@Cls(_showImageWatermark)" @onclick="async () => { _showImageWatermark = !_showImageWatermark; await ProcessAsync(); }">Enable</button>
            </div>
        </section>

        <section class="ctrl-card">
            <h3 class="ctrl-title">Output Format</h3>
            <div class="toggle-row">
                @foreach (var fmt in OutputFormats)
                {
                    var f = fmt;
                    <button class="@(f == _outputFormat ? "toggle on" : "toggle")"
                            @onclick="@(async () => { _outputFormat = f; await ProcessAsync(); })">
                        @f.ToUpper()
                    </button>
                }
            </div>
            @if (_outputFormat != "png")
            {
                <div class="slider-row" style="margin-top:.5rem">
                    <span class="slider-label">Quality</span>
                    <input type="range" min="1" max="100" value="@_outputQuality"
                           @oninput="e => OnSlider(e, v => _outputQuality = v)"
                           class="slider" />
                    <span class="slider-val">@_outputQuality</span>
                </div>
            }
        </section>

        <section class="ctrl-card ctrl-reset">
            <button class="btn-ghost btn-full" @onclick="ResetEffectsAsync">Reset all effects</button>
        </section>

    </div>

</div>

@code {
    private byte[]? _originalBytes;
    private string? _processedDataUrl;
    private bool    _processing;
    private long    _elapsedMs;

    // ── Presets ──────────────────────────────────────────────────────────────
    private bool _vintage, _blackWhite, _warmTone, _coolTone, _softFocus, _darkOverlay;

    // ── Color ────────────────────────────────────────────────────────────────
    private bool _grayscale, _sepia;

    // ── Adjust ───────────────────────────────────────────────────────────────
    private int _brightness;        // -100 to 100  →  / 100f
    private int _contrast;          // -100 to 100  →  / 100f
    private int _opacity = 100;     //    0 to 100  →  / 100f

    // ── Focus ─────────────────────────────────────────────────────────────────
    private int  _blur;             // box blur radius 0–20
    private int  _gaussianBlur;     // 0–50  →  / 10f  sigma
    private bool _sharpen;

    // ── Transform ────────────────────────────────────────────────────────────
    private int  _rotate;           // -180 to 180 degrees
    private int  _scale = 100;      // 25 to 200 percent  →  / 100.0 factor
    private bool _flipH, _flipV;

    // ── Artistic ─────────────────────────────────────────────────────────────
    private int _pixelate;

    // ── Text watermark ────────────────────────────────────────────────────────
    private bool   _showWatermark;
    private string _watermarkText            = "© VisionSharp";
    private string _watermarkPositionStr     = nameof(WatermarkPosition.BottomRight);
    private int    _watermarkOpacity         = 70;  // 0–100  →  / 100f
    private int    _watermarkFontSize        = 48;

    // ── Image watermark ───────────────────────────────────────────────────────
    private bool   _showImageWatermark;
    private string _imageWatermarkPositionStr = nameof(WatermarkPosition.Center);
    private int    _imageWatermarkOpacity     = 70;  // 0–100  →  / 100f

    // ── Output format ─────────────────────────────────────────────────────────
    private string _outputFormat  = "jpeg";
    private int    _outputQuality = 90;

    private static readonly string[] OutputFormats = ["jpeg", "png", "webp"];

    private string  _urlInput   = string.Empty;
    private bool    _urlLoading;
    private string? _urlError;

    private CancellationTokenSource? _cts;
    private Timer? _debounce;

    // ── CSS helpers ──────────────────────────────────────────────────────────
    private static string Cls(bool on) => on ? "toggle on" : "toggle";

    private static string FormatPosition(WatermarkPosition pos) => pos switch
    {
        WatermarkPosition.TopLeft      => "Top Left",
        WatermarkPosition.TopCenter    => "Top Center",
        WatermarkPosition.TopRight     => "Top Right",
        WatermarkPosition.MiddleLeft   => "Middle Left",
        WatermarkPosition.Center       => "Center",
        WatermarkPosition.MiddleRight  => "Middle Right",
        WatermarkPosition.BottomLeft   => "Bottom Left",
        WatermarkPosition.BottomCenter => "Bottom Center",
        WatermarkPosition.BottomRight  => "Bottom Right",
        _                              => pos.ToString()
    };

    // ── Init ─────────────────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        var path = Path.Combine(Env.WebRootPath, "image-sample.jpg");

        var outputDir = Path.Combine(Env.WebRootPath, "output-test");
        if (Directory.Exists(outputDir)) Directory.Delete(outputDir, true);
        Directory.CreateDirectory(outputDir);

        _originalBytes = await File.ReadAllBytesAsync(path);
        await ProcessAsync();
    }

    // ── File upload ──────────────────────────────────────────────────────────
    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        using var ms = new MemoryStream();
        await e.File.OpenReadStream(maxAllowedSize: 30 * 1024 * 1024).CopyToAsync(ms);
        _originalBytes = ms.ToArray();
        await ProcessAsync();
    }

    // ── URL load ─────────────────────────────────────────────────────────────
    private async Task LoadFromUrlAsync()
    {
        _urlError = null;
        if (!Uri.TryCreate(_urlInput, UriKind.Absolute, out var uri) ||
            (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
        {
            _urlError = "Please enter a valid HTTP or HTTPS URL.";
            return;
        }

        _urlLoading = true;
        StateHasChanged();
        try
        {
            _originalBytes = await ImageFactory.OpenAsync(uri).ToBytesAsync();
            await ProcessAsync();
        }
        catch (Exception ex)
        {
            _urlError = $"Could not load image: {ex.Message}";
        }
        finally
        {
            _urlLoading = false;
            StateHasChanged();
        }
    }

    // ── Slider / text handlers (debounced) ───────────────────────────────────
    private void OnSlider(ChangeEventArgs e, Action<int> set)
    {
        if (int.TryParse(e.Value?.ToString(), out var v)) set(v);
        Debounce();
    }

    private void OnWatermarkInput(ChangeEventArgs e)
    {
        _watermarkText = e.Value?.ToString() ?? "";
        Debounce();
    }

    private void Debounce()
    {
        _debounce?.Dispose();
        _debounce = new Timer(_ => InvokeAsync(ProcessAsync), null, 250, Timeout.Infinite);
    }

    // ── Processing ───────────────────────────────────────────────────────────
    private async Task ProcessAsync()
    {
        if (_originalBytes is null) return;

        _cts?.Cancel();
        _cts = new CancellationTokenSource();
        var token = _cts.Token;

        _processing = true;
        StateHasChanged();

        try
        {
            var sw = System.Diagnostics.Stopwatch.StartNew();

            var builder = ImageFactory.OpenAsync(_originalBytes);

            // Color
            if (_grayscale)   builder = builder.Grayscale();
            if (_sepia)       builder = builder.Sepia();

            // Presets
            if (_warmTone)    builder = builder.WarmTone();
            if (_coolTone)    builder = builder.CoolTone();
            if (_vintage)     builder = builder.Vintage();
            if (_blackWhite)  builder = builder.BlackAndWhite();
            if (_softFocus)   builder = builder.SoftFocus();

            // Adjust
            if (_brightness != 0) builder = builder.Brightness(_brightness / 100f);
            if (_contrast   != 0) builder = builder.Contrast(_contrast / 100f);
            if (_opacity < 100)   builder = builder.Opacity(_opacity / 100f);

            // Focus
            if (_sharpen)          builder = builder.Sharpen();
            if (_blur > 0)         builder = builder.Blur(_blur);
            if (_gaussianBlur > 0) builder = builder.GaussianBlur(_gaussianBlur / 10f);

            // Artistic
            if (_pixelate > 0) builder = builder.Pixelate(_pixelate);

            // Transform
            if (_scale != 100) builder = builder.Scale(_scale / 100.0);
            if (_rotate != 0)  builder = builder.Rotate(_rotate);
            if (_flipH)        builder = builder.FlipHorizontal();
            if (_flipV)        builder = builder.FlipVertical();

            // Dark overlay
            if (_darkOverlay) builder = builder.DarkOverlay();

            // Text watermark
            if (_showWatermark && !string.IsNullOrWhiteSpace(_watermarkText))
            {
                var pos = Enum.Parse<WatermarkPosition>(_watermarkPositionStr);
                builder = builder.WatermarkText(_watermarkText, opts =>
                {
                    opts.Position = pos;
                    opts.FontSize = _watermarkFontSize;
                    opts.Color    = "#FFFFFF";
                    opts.Opacity  = _watermarkOpacity / 100f;
                    opts.PaddingX = 16;
                    opts.PaddingY = 16;
                });
            }

            // Image watermark
            if (_showImageWatermark)
            {
                var imgLogoPath = Path.Combine(Env.WebRootPath, "logo.png");
                var scaledLogoPath = Path.Combine(Env.WebRootPath, "output-test", "scaled-logo.png");
                var imgPos = Enum.Parse<WatermarkPosition>(_imageWatermarkPositionStr);

                _ = await ImageFactory.OpenAsync(imgLogoPath)
                    .Scale(10)
                    .ToWebp()
                    .SaveAsync(scaledLogoPath, cancellationToken: token);

                builder = builder.Watermark(scaledLogoPath, imgPos, _imageWatermarkOpacity / 100f);
            }

            // Output format
            builder = _outputFormat switch
            {
                "png"  => builder.ToPng(),
                "webp" => builder.ToWebp(_outputQuality),
                _      => builder.ToJpeg(_outputQuality),
            };

            var bytes = await builder.ToBytesAsync(token);
            sw.Stop();

            if (!token.IsCancellationRequested)
            {
                var mime = _outputFormat switch
                {
                    "png"  => "image/png",
                    "webp" => "image/webp",
                    _      => "image/jpeg",
                };
                _processedDataUrl = $"data:{mime};base64,{Convert.ToBase64String(bytes)}";
                _elapsedMs = sw.ElapsedMilliseconds;
            }

            StateHasChanged();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"[VisionSharp.BlazorDemo] {ex.Message}");
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _processing = false;
                StateHasChanged();
            }
        }
    }

    // ── Reset ────────────────────────────────────────────────────────────────
    private async Task ResetEffectsAsync()
    {
        _grayscale = _sepia = _sharpen = _flipH = _flipV = false;
        _vintage = _blackWhite = _warmTone = _coolTone = _softFocus = _darkOverlay = false;
        _showWatermark = _showImageWatermark = false;

        _brightness = _contrast = _blur = _gaussianBlur = _rotate = _pixelate = 0;
        _opacity = 100;
        _scale = 100;

        _watermarkText             = "© VisionSharp";
        _watermarkPositionStr      = nameof(WatermarkPosition.BottomRight);
        _watermarkOpacity          = 70;
        _watermarkFontSize         = 48;
        _imageWatermarkPositionStr = nameof(WatermarkPosition.Center);
        _imageWatermarkOpacity     = 70;

        _outputFormat  = "jpeg";
        _outputQuality = 90;

        await ProcessAsync();
    }

    public void Dispose()
    {
        _cts?.Dispose();
        _debounce?.Dispose();
    }
}
